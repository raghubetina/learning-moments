{
  "name": "learning-moments",
  "version": "0.2.1",
  "description": "A Claude Code integration that adds brief checks of developer understanding to AI-assisted programming.",
  "type": "module",
  "bin": {
    "learning-moments": "src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src/",
    "MANIFEST.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "scripts": {
    "test": "vitest run",
    "audit": "node src/cli.js audit",
    "build-manifest": "node scripts/build-manifest.js",
    "release": "node scripts/build-manifest.js && vitest run && npm pack --dry-run"
  },
  "keywords": [
    "claude-code",
    "claude-code-hooks",
    "hooks",
    "learning",
    "ai-assisted-programming",
    "developer-tools"
  ],
  "author": "Raghu Betina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raghubetina/learning-moments.git"
  },
  "bugs": {
    "url": "https://github.com/raghubetina/learning-moments/issues"
  },
  "homepage": "https://github.com/raghubetina/learning-moments#readme",
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
