{
  "name": "learning-moments",
  "version": "0.1.1",
  "description": "Learning Moments is a local Claude Code hook tool for asking brief questions tied to the code you are working on during AI-assisted programming.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "learning-moments": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude-code",
    "claude-code-hooks",
    "hooks",
    "learning",
    "ai-assisted-programming",
    "developer-tools"
  ],
  "author": "Raghu Betina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raghubetina/learning-moments.git"
  },
  "bugs": {
    "url": "https://github.com/raghubetina/learning-moments/issues"
  },
  "homepage": "https://github.com/raghubetina/learning-moments#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "minimatch": "^10.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
